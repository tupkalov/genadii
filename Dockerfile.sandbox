FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Сервер runner'а + whitelist пакетов, доступных пользовательскому коду
RUN pip install --no-cache-dir \
    "fastapi>=0.115" "uvicorn>=0.32" "pydantic>=2" \
    "requests>=2.32" "httpx>=0.28" "beautifulsoup4>=4.12"

RUN useradd --create-home sandbox

WORKDIR /srv
COPY sandbox/runner.py .

USER sandbox
EXPOSE 8100

CMD ["uvicorn", "runner:app", "--host", "0.0.0.0", "--port", "8100"]
