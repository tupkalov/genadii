# --- Telegram ---
BOT_TOKEN=123456789:REPLACE_ME
# Твой Telegram ID (и других админов через запятую). Узнать: @userinfobot
ADMIN_TG_IDS=11111111

# --- Postgres (значения используются и контейнером postgres, и приложением) ---
POSTGRES_USER=gennady
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gennady
DATABASE_URL=postgresql+asyncpg://gennady:change-me@postgres:5432/gennady

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- LLM (используется с Milestone 3) ---
OPENROUTER_API_KEY=
DEFAULT_MODEL=deepseek/deepseek-chat

# --- Мультимодальность: vision/аудио/генерация картинок (через OpenRouter) ---
VISION_MODEL=google/gemini-2.5-flash
AUDIO_MODEL=google/gemini-2.5-flash
IMAGE_MODEL=google/gemini-2.5-flash-image

# --- Web search (Milestone 6): https://tavily.com, 1000 запросов/мес бесплатно ---
TAVILY_API_KEY=

# --- Embeddings для семантической памяти (Milestone 4) ---
# Идут через OpenRouter тем же ключом. Размерность должна совпадать с Vector(1536).
EMBEDDING_MODEL=openai/text-embedding-3-small

# Локальное время для напоминаний и «сейчас» в промпте
TIMEZONE=Europe/Moscow

# Пауза (сек) после последнего сообщения перед ответом — серия сообщений
# получает один общий ответ
REPLY_DEBOUNCE_SECONDS=3.0

# Стриминг: печатать ответ постепенно (правкой сообщения)
STREAM_RESPONSES=true

ENV=dev

# Дефолтный месячный лимит LLM-расходов на чат, $. 0 = без лимита. Точечно: /budget
DEFAULT_MONTHLY_BUDGET_USD=0
